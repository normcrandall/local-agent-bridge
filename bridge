#!/bin/zsh
set -eu

ROOT="${0:A:h}"
COMMAND="${1:-}"

case "$COMMAND" in
  talk)
    shift
    exec node "$ROOT/scripts/bridge-talk.mjs" "$@"
    ;;
  start)
    shift
    exec node "$ROOT/scripts/workflow-launcher.mjs" "$@"
    ;;
  watchdog)
    shift
    exec node "$ROOT/scripts/codex-turn-watchdog.mjs" "$@"
    ;;
  doctor)
    shift
    if (( $# == 0 )); then
      exec npm --prefix "$ROOT" run doctor
    fi
    exec node "$ROOT/scripts/collaboration-doctor.mjs" "$@"
    ;;
  smoke)
    exec npm --prefix "$ROOT" run smoke
    ;;
  skills)
    shift
    exec node "$ROOT/scripts/skill-portability.mjs" "$@"
    ;;
  status|capabilities|roles|preflight|recover|archive|prune|worktree|ci|reconcile|usage|bundle)
    shift
    exec node "$ROOT/scripts/bridge-ops.mjs" "$COMMAND" "$@"
    ;;
  ""|help|--help|-h)
    print "Usage: ./bridge <talk|start|watchdog|doctor|smoke|skills|status|capabilities|roles|preflight|recover|archive|prune|worktree|ci|reconcile|usage|bundle> [options]"
    print "Run './bridge talk --help' for conversation options."
    ;;
  *)
    print -u2 "Unknown bridge command: $COMMAND"
    exit 2
    ;;
esac
