{
  "version": 1,
  "compatibility": {
    "allowPatFallback": false
  },
  "github": {
    "mergeEnforcement": "broker"
  },
  "mergePolicy": {
    "trustedHumanReviewers": ["your-github-login"],
    "autonomousMergeRepositories": [
      "your-personal-account/*",
      "your-organization/*"
    ]
  },
  "roles": {
    "builder": {
      "appId": "YOUR_BUILDER_APP_ID",
      "expectedLogin": "your-builder-app[bot]",
      "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-builder-app.pem",
      "installations": {
        "your-personal-account": 11111111,
        "your-organization": 22222222
      }
    },
    "reviewers": {
      "claude": {
        "appId": "YOUR_CLAUDE_REVIEWER_APP_ID",
        "expectedLogin": "your-claude-reviewer[bot]",
        "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-claude-reviewer.pem",
        "installations": {
          "your-personal-account": 33333333,
          "your-organization": 44444444
        }
      },
      "codex": {
        "appId": "YOUR_CODEX_REVIEWER_APP_ID",
        "expectedLogin": "your-codex-reviewer[bot]",
        "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-codex-reviewer.pem",
        "installations": {
          "your-personal-account": 55555555,
          "your-organization": 66666666
        }
      },
      "antigravity": {
        "appId": "YOUR_GEMINI_REVIEWER_APP_ID",
        "expectedLogin": "your-gemini-reviewer[bot]",
        "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-gemini-reviewer.pem",
        "installations": {
          "your-personal-account": 77777777,
          "your-organization": 88888888
        }
      },
      "ollama": {
        "appId": "YOUR_LOCAL_REVIEWER_APP_ID",
        "expectedLogin": "your-local-reviewer[bot]",
        "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-local-reviewer.pem",
        "installations": {
          "your-personal-account": 99999999,
          "your-organization": 10101010
        }
      },
      "docker": {
        "appId": "YOUR_DOCKER_REVIEWER_APP_ID",
        "expectedLogin": "your-docker-reviewer[bot]",
        "privateKeyPath": "~/.config/local-agent-bridge/github-apps/your-docker-reviewer.pem",
        "installations": {
          "your-personal-account": 11111111,
          "your-organization": 12121212
        }
      }
    }
  }
}
